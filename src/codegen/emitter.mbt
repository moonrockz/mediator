///|
/// Emit MoonBit source for Request enum, Response enum, and dispatch function.
pub fn emit_dispatch(result : ScanResult) -> String {
  let buf = StringBuilder::new()
  buf.write_string("// Generated by mediator gen — DO NOT EDIT\n")
  buf.write_string("//\n")
  buf.write_string("// Regenerate with: mediator gen -d <dir> -o <output>\n\n")
  if result.handlers.length() == 0 {
    buf.write_string(
      "// No handlers found; add handler functions and run mediator gen\n",
    )
    return buf.to_string()
  }
  // Request enum
  buf.write_string("pub enum Request {\n")
  for h in result.handlers {
    buf.write_string("  " + h.message_type + "(" + h.message_type + ")\n")
  }
  buf.write_string("}\n\n")
  // Type alias so struct field type starts with uppercase (MoonBit requirement). Uses default package alias @core.
  buf.write_string("type MediatorResult[T] = @core.Result[T]\n\n")
  for h in result.handlers {
    buf.write_string(
      "pub struct " +
      h.response_type +
      "Result { value : MediatorResult[" +
      h.response_type +
      "] }\n",
    )
  }
  buf.write_string("\npub enum Response {\n")
  for h in result.handlers {
    buf.write_string(
      "  " + h.response_type + "Result(" + h.response_type + "Result)\n",
    )
  }
  buf.write_string("}\n\n")
  // dispatch function
  buf.write_string("pub fn dispatch(req : Request) -> Response {\n")
  buf.write_string("  match req {\n")
  for h in result.handlers {
    let line = "    " +
      h.message_type +
      "(r) => " +
      h.response_type +
      "Result({ value : " +
      h.fn_name +
      "(r) })\n"
    buf.write_string(line)
  }
  buf.write_string("  }\n")
  buf.write_string("}\n")
  buf.to_string()
}
