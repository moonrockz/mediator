///|
/// Emit MoonBit source for Request enum, Response enum, and dispatch function.
/// Uses multi-line strings with interpolation for clarity and maintainability.
pub fn emit_dispatch(result : ScanResult) -> String {
  if result.handlers.length() == 0 {
    return (
      #|// Generated by mediator gen — DO NOT EDIT
      #|//
      #|// No handlers found; add handler functions and run mediator gen
    )
  }
  let request_lines = build_request_variant_lines(result.handlers)
  let response_struct_lines = build_response_struct_lines(result.handlers)
  let response_variant_lines = build_response_variant_lines(result.handlers)
  let dispatch_arm_lines = build_dispatch_arm_lines(result.handlers)
  (
    #|// Generated by mediator gen — DO NOT EDIT
    #|//
    #|// Regenerate with: mediator gen -d <dir> -o <output>
    #|
    #|pub enum Request {
    $|\{request_lines}
    #|}
    #|
    #|type MediatorResult[T] = @core.Result[T]
    #|
    $|\{response_struct_lines}
    #|
    #|pub enum Response {
    $|\{response_variant_lines}
    #|}
    #|
    #|pub fn dispatch(req : Request) -> Response {
    #|  match req {
    $|\{dispatch_arm_lines}
    #|  }
    #|}
  )
}

fn build_request_variant_lines(handlers : Array[HandlerInfo]) -> String {
  let buf = StringBuilder::new()
  for h in handlers {
    buf.write_string("  " + h.message_type + "(" + h.message_type + ")\n")
  }
  buf.to_string()
}

fn build_response_struct_lines(handlers : Array[HandlerInfo]) -> String {
  let buf = StringBuilder::new()
  for h in handlers {
    buf.write_string(
      "pub struct " +
      h.response_type +
      "Result { value : MediatorResult[" +
      h.response_type +
      "] }\n",
    )
  }
  buf.to_string()
}

fn build_response_variant_lines(handlers : Array[HandlerInfo]) -> String {
  let buf = StringBuilder::new()
  for h in handlers {
    buf.write_string(
      "  " + h.response_type + "Result(" + h.response_type + "Result)\n",
    )
  }
  buf.to_string()
}

fn build_dispatch_arm_lines(handlers : Array[HandlerInfo]) -> String {
  let buf = StringBuilder::new()
  for h in handlers {
    buf.write_string(
      "    " +
      h.message_type +
      "(r) => " +
      h.response_type +
      "Result({ value : " +
      h.fn_name +
      "(r) })\n",
    )
  }
  buf.to_string()
}
